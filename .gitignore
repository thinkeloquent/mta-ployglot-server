# OS / editor
.DS_Store
*.swp
.vscode/
.idea/
__pycache__
node_modules
examples/**/dist

.env
.env.local
.venv

# Runtime / caches
.smoke-logs/
*.log

# Host-direct dev mode staging (make dev / dev-fastify / dev-fastapi).
# Use .dev/* + negation so we can re-include release manifests below.
# (gitignore can't re-include children of a fully-excluded directory.)
.dev/*
# Exception: release manifests are committed by the PR-merge workflow
# (.github/workflows/release-assemble-on-pr-merge.yml) to the release branch
# so consumers can read what SHAs were assembled.
!.dev/release-manifests/
*.pid
playwright-tests
# Local symlink to the sibling checkout `../mta-ployglot-server-bootstrap` (formerly a submodule)
ployglots/mta-ployglot-server-bootstrap

# Generated by scripts/workspace/emit-*.sh — never commit. Anchored to
# the orchestration shell root so a sibling repo's own files (e.g.
# ployglots/<sibling>/Cargo.toml) remain tracked normally.
/pnpm-workspace.yaml
/go.work
/go.work.sum
/Cargo.toml
/Cargo.lock
/target/
# Generated by scripts/workspace/emit-make-vars.sh
# /Makefile.entries

# Local-only Makefile parity baseline (scripts/workspace/makefile-parity.sh)
/.makefile-parity-snapshot.txt

# Rendered tenant manifests (Makefile.tenants -> tenant-render)
/dist/
