{
  "name": "mta-fastify-server",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone fastify server that extends @ployglot/fastify-server from the mta-ployglot-server-bootstrap submodule.",
  "type": "module",
  "scripts": {
    "start": "node main.mjs",
    "dev": "node --watch main.mjs",
    "test": "vitest run --config vitest.config.mjs",
    "clean": "rm -rf node_modules package-lock.json"
  },
  "dependencies": {
    "fastify-server": "file:../../ployglots/mta-ployglot-server-bootstrap/fastify_server",
    "@mta/print-routes-fastify": "file:../../ployglots/mta-ployglot-server-print-routes/packages/mjs",
    "fastify-plugin": "^5.0.0",
    "@polyglot/fetch-http-client": "file:../../ployglots/mta-ployglot-pkg-fetch-client/packages/ts",
    "@org/env-resolve": "file:../../ployglots/mta-ployglot-pkg-env-resolve/packages/ts",
    "@ployglot/app-yaml-loader": "file:../../ployglots/mta-ployglot-pkg-app-yaml-loader/packages/mjs",
    "@ployglot/runtime-template-resolver": "file:../../ployglots/mta-ployglot-pkg-app-yaml-overwrite/packages/engine-mjs",
    "@ployglot/app-yaml-from-context": "file:../../ployglots/mta-ployglot-pkg-app-yaml-overwrite/packages/applier-mjs",
    "@ployglot/app-yaml-config": "file:../../ployglots/mta-ployglot-pkg-app-yaml-config/packages/mjs",
    "@ployglot/app-yaml-fetch-config": "file:../../ployglots/mta-ployglot-pkg-app-yaml-fetch-config/packages/mjs"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
