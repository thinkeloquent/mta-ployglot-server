{
  "name": "mta-ployglot-api-aws-s3",
  "private": true,
  "version": "0.0.0",
  "description": "Polyglot (Node + Python) API for the AWS S3 HTTPS client builder — proxy + timeouts + path-style + endpoint resolution.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/mjs"
  ],
  "scripts": {
    "test": "sh -c 'pnpm --filter \"./packages/mjs\" run --if-present test'",
    "lint": "sh -c 'pnpm --filter \"./packages/mjs\" run --if-present lint'",
    "build": "sh -c 'pnpm --filter \"./packages/mjs\" run --if-present build'"
  }
}
