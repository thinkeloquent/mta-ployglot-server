{
  "name": "@mta/polyglot-aws-s3",
  "version": "0.1.0",
  "description": "Polyglot AWS S3 HTTPS client builder (Node) — proxy + timeouts + path-style + endpoint resolution.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "@smithy/node-http-handler": "^3.3.3"
  },
  "optionalDependencies": {
    "https-proxy-agent": "^7.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
