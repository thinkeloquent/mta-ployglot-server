# .env.example — copy to .env and adjust to taste.
#
# Loaded by Makefile.vars (between `?=` defaults and the conditional
# export blocks). Format is `KEY=VALUE`, one per line. Make includes the
# file as Makefile syntax, so:
#   - no surrounding quotes (`KEY=value`, NOT `KEY="value"`)
#   - no shell expansions (`${OTHER}` will not interpolate the way you
#     expect — use `$(OTHER)` if you need a make-variable reference)
#   - `#` starts a comment

# ---------------------------------------------------------------------------
# Ports (consumed by docker-compose.yml). Container-internal ports are fixed
# (3000 for fastify, 8080 for fastapi); only the host-side mapping is here.
# ---------------------------------------------------------------------------
FASTIFY_PORT=5100
FASTAPI_PORT=5200

# ---------------------------------------------------------------------------
# Registries — single source of truth for each ecosystem's package fetches.
# ---------------------------------------------------------------------------
# Node side. Default = http://localhost:4873 (Verdaccio).
# NPM_REGISTRY=https://registry.npmjs.org

# Python side. PYTHON_REGISTRY_URL fans out to pip + uv via PIP_INDEX_URL,
# UV_INDEX_URL, and UV_DEFAULT_INDEX (Makefile.vars wires this). Override
# any tool-specific var directly to take precedence.
# PYTHON_REGISTRY_URL=https://internal-pypi.corp.com/simple/
# PYTHON_REGISTRY_NAME=corp-pypi

# pip-only knobs (use only if your registry needs an explicit trusted host
# or a non-default index name).
# PIP_INDEX=corp-pypi
# PIP_TRUSTED_HOST=internal-pypi.corp.com

# ---------------------------------------------------------------------------
# CA certs — point each tool at the corporate CA bundle. Default sentinel
# is `None`/`NONE`, which means "do not pass the flag through."
# ---------------------------------------------------------------------------
# PIP_CERT=/etc/ssl/certs/corp-ca.pem
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/corp-ca.pem
# REQUEST_CS_BUNDLE=/etc/ssl/certs/corp-ca.pem
# SSL_CERT_FILE=/etc/ssl/certs/corp-ca.pem

# ---------------------------------------------------------------------------
# TLS verification toggles — placeholder default `0` means "leave the tool's
# built-in verification alone." Set to `0` to DISABLE verification (only
# for known-bad self-signed setups), `1` to force-enable.
# ---------------------------------------------------------------------------
# NODE_TLS_REJECT_UNAUTHORIZED=0
# SSL_CERT_VERIFY=0

# uv 0.9.x ships with rustls + bundled webpki CAs and does NOT consult the
# macOS Keychain. Behind a corporate Artifactory whose TLS cert is signed
# by an internally-installed root CA, `uv pip install` fails with
# `invalid peer certificate: UnknownIssuer`. Setting UV_NATIVE_TLS=true
# tells uv to use the OS-native trust store, which picks up the corp root.
# Set this if you see UnknownIssuer errors during `make dev` or `make prod`.
# UV_NATIVE_TLS=true

# ---------------------------------------------------------------------------
# Proxy bypass for the registry host(s). If your corp HTTPS proxy refuses to
# tunnel to the internal registry, list its hostnames here so curl/pip/uv
# skip the proxy entirely.
# ---------------------------------------------------------------------------
# NO_PROXY=internal-pypi.corp.com,.corp.com,localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Prod-mode (Makefile.prod) — defaults reuse FASTIFY_PORT / FASTAPI_PORT so
# `make dev` and `make prod` cannot both run on the same host. Override one
# pair when you need them side-by-side.
# ---------------------------------------------------------------------------
# PROD_FASTIFY_PORT=6100
# PROD_FASTAPI_PORT=6200
# PROD_FASTIFY_HOST=0.0.0.0
# PROD_FASTAPI_HOST=0.0.0.0
# PROD_FASTAPI_WORKERS=2     # currently a no-op; main.py is single-worker
